# =======================================
# AIRTABLE CONFIG
# =======================================
# Obtén tu API Key en: https://airtable.com/create/tokens
# Permisos necesarios: data.records:read, data.records:write
VITE_AIRTABLE_TOKEN=tu_api_key_de_airtable_aqui

# ID de tu Base (lo ves en la URL: airtable.com/appXXXXXXX/...)
VITE_AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# Nombre exacto de tu tabla (sensible a mayúsculas)
VITE_AIRTABLE_TABLE=Clientes
